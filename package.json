{
  "name": "ceia_os",
  "version": "1.0.0",
  "description": "CeIA OS - Sistema de Gestão para Restaurantes",
  "main": "electron-main.js",
  "author": "CeIA",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "bot": "node index.js",
    "build": "electron-builder --linux --win",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.ceia.os",
    "productName": "CeIA OS",
    "copyright": "Copyright © 2026 CeIA",
    "asar": true,
    "asarUnpack": [
      "node_modules/sqlite3/**",
      "node_modules/@mapbox/node-pre-gyp/**"
    ],
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "app.js",
      "index.js",
      "src/**/*",
      "ui/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!**/*.md",
      "!**/*.map"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "synopsis": "Sistema de gestão para restaurantes",
      "maintainer": "CeIA <contato@ceia.app>"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["pt_BR"],
      "language": "1046"
    }
  },
  "keywords": [],
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "pdf-to-printer": "^5.8.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.15.0"
  }
}
