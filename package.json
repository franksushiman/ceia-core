{
  "name": "ceia_os",
  "version": "1.0.6",
  "description": "CeIA OS - Sistema de Gestão para Restaurantes",
  "main": "electron-main.js",
  "author": "CeIA",
  "desktopName": "ceia-os",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "bot": "node index.js",
    "build": "electron-builder --linux --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.ceia.os",
    "productName": "CeIA OS",
    "artifactName": "CeIA-OS-${version}.${ext}",
    "copyright": "Copyright © 2026 CeIA",
    "asar": true,
    "forceCodeSigning": false,
    "asarUnpack": [
      "node_modules/sqlite3/**",
      "node_modules/@mapbox/node-pre-gyp/**",
      "build/icon.png"
    ],
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "build/icon.png",
      "app.js",
      "index.js",
      "src/**/*",
      "ui/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!**/*.md",
      "!**/*.map"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "franksushiman",
        "repo": "ceia-core",
        "private": false
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "build/icons",
      "category": "Office",
      "synopsis": "Sistema de gestão para restaurantes",
      "maintainer": "CeIA <contato@ceia.app>",
      "syncDesktopName": true
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "notarize": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["pt_BR"],
      "language": "1046"
    }
  },
  "keywords": [],
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "pdf-to-printer": "^5.8.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.15.0"
  }
}
